use chrono::Utc;
use sentinel_db::insert_ndvi_result;
use sentinel_types::PipelineResult;
use testcontainers::clients::Cli;
use testcontainers_modules::postgres::Postgres;

fn make_result() -> PipelineResult {
    PipelineResult {
        captured_at:  Utc::now(),
        satellite_id: "SENTINEL-2A".into(),
        min_lon: -122.95,
        max_lon: -122.65,
        min_lat: 49.05,
        max_lat: 49.35,
        mean_ndvi: 0.45,
        max_ndvi: 0.82,
        min_ndvi: -0.12,
        valid_pixels: 100_000,
        tif_path: "../../output/ndvi/test.tif".into(),
    }
}

#[test]
fn insert_ndvi_result_succeeds() {
    let docker = Cli::default();
    let container = docker.run(Postgres::default());
    let port = container.get_host_port_ipv4(5432);

    std::env::set_var(
        "DATABASE_URL",
        format!("host=localhost port={port} user=postgres password=postgres dbname=postgres"),
    );

    let mut client = postgres::Client::connect(
        &std::env::var("DATABASE_URL").unwrap(),
        postgres::NoTls,
    ).unwrap();

    client.batch_execute("
        CREATE EXTENSION IF NOT EXISTS postgis;
        CREATE TABLE ndvi_history (
            id SERIAL PRIMARY KEY,
            captured_at TIMESTAMPTZ NOT NULL,
            satellite_id TEXT NOT NULL,
            min_lon DOUBLE PRECISION NOT NULL,
            max_lon DOUBLE PRECISION NOT NULL,
            min_lat DOUBLE PRECISION NOT NULL,
            max_lat DOUBLE PRECISION NOT NULL,
            mean_ndvi REAL NOT NULL,
            max_ndvi REAL NOT NULL,
            min_ndvi REAL NOT NULL,
            valid_pixels INTEGER NOT NULL,
            tif_path TEXT NOT NULL,
            bbox GEOMETRY(POLYGON, 4326)
        );
    ").unwrap();

    let result = insert_ndvi_result(&make_result());
    assert!(result.is_ok(), "Insert failed: {:?}", result.err());

    let row = client
        .query_one("SELECT mean_ndvi, valid_pixels FROM ndvi_history", &[])
        .unwrap();

    let mean: f32 = row.get(0);
    let pixels: i32 = row.get(1);

    assert!((mean - 0.45).abs() < 1e-5);
    assert_eq!(pixels, 100_000);
}

#[test]
fn insert_ndvi_result_fails_on_bad_connection() {
    std::env::set_var("DATABASE_URL", "host=localhost port=1 user=nobody dbname=nobody");

    let result = insert_ndvi_result(&make_result());
    assert!(result.is_err(), "Expected error on bad connection");
}